DATABASE_URL="postgresql://saga:saga@localhost:5432/saga_sms_producer?schema=public"
ADMIN_PASSWORD="change-me-local"
APP_BASE_URL="http://localhost:3000"
INTERNAL_API_KEY="change-me-internal-local"

# Demo mode works without Twilio. Leave these blank unless testing live SMS.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=
TWILIO_CONVERSATIONS_SERVICE_SID=
TWILIO_VALIDATE_WEBHOOKS=false
MESSAGING_PROVIDER=MOCK
CONVERSATION_ENGINE_MODE=shadow
CONVERSATION_ENGINE_ACTIVE=false
SMS_SENDS_DISABLED=true
SMS_REQUIRE_ALLOWLIST=true
SMS_ALLOWED_NUMBERS=
TWILIO_STAGING_MODE=
PILOT_STAGE=internal_test
PILOT_REPLY_MODE=draft_only
SMS_ACCESS_MODE=allowlist_only
PUBLIC_BETA_ENABLED=false
PUBLIC_LAUNCH_ENABLED=false
SMS_COMPLIANCE_APPROVED=false
PILOT_SUPPORT_CONTACT=
PILOT_PRIVACY_URL=
PILOT_TERMS_URL=
SMS_DAILY_SEND_CAP=
SMS_PER_NUMBER_DAILY_SEND_CAP=
SMS_AUTONOMOUS_REPLY_DAILY_CAP=
SMS_DAILY_INBOUND_CAP=
PILOT_MAX_ACTIVE_PARTICIPANTS=
PRIVATE_BETA_MAX_ACTIVE_PARTICIPANTS=
PUBLIC_BETA_MAX_ACTIVE_PARTICIPANTS=
PUBLIC_BETA_NEW_USER_DAILY_CAP=
MESSAGE_PROCESSING_MODE=sync

# Talent discovery stays internal-only unless an admin explicitly enables shadow research.
PUBLIC_WEB_RESEARCH_ENABLED=false
PUBLIC_WEB_RESEARCH_MODE=disabled
PUBLIC_WEB_RESEARCH_PROVIDER=none
PUBLIC_WEB_RESEARCH_MAX_RESULTS=10
PUBLIC_WEB_RESEARCH_REQUIRE_CITATIONS=true

# Optional LLM. Leave blank for deterministic fallback mode.
LLM_PROVIDER=fallback
LLM_MODE=fallback
LLM_TIMEOUT_MS=8000
LLM_DAILY_CALL_CAP=
LLM_LOG_PROMPTS=false
LLM_LOG_OUTPUTS=false
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
