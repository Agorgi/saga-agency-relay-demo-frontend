  riskFlags                 Json                            @default("[]")
  missingEvidence           Json                            @default("[]")
  contactabilitySummary     Json                            @default("{}")
  sourceMode                CandidateGraphMatchSourceMode
  reviewStatus              CandidateGraphMatchReviewStatus @default(SUGGESTED)
  organizerSafeSummary      String?
  adminNotes                String?
  createdAt                 DateTime                        @default(now())
  updatedAt                 DateTime                        @updatedAt
  matchRun                  CandidateGraphMatchRun          @relation(fields: [matchRunId], references: [id], onDelete: Cascade)

  @@index([matchRunId])
  @@index([candidateSearchProfileId])
  @@index([personId])
  @@index([creatorProfileId])
  @@index([contactId])
  @@index([talentCandidateId])
  @@index([candidateRecommendationId])
  @@index([publicWebResearchResultId])
  @@index([role])
  @@index([totalScore])
  @@index([proximityTier])
  @@index([sourceMode])
  @@index([reviewStatus])
  @@index([createdAt])
}

model RelationshipEdge {
  id               String           @id @default(cuid())
  fromPersonId     String
  toPersonId       String
  relationshipType RelationshipType
  strength         Float            @default(1)
  metadata         Json?
  createdAt        DateTime         @default(now())
  fromPerson       Person           @relation("RelationshipFrom", fields: [fromPersonId], references: [id], onDelete: Cascade)
  toPerson         Person           @relation("RelationshipTo", fields: [toPersonId], references: [id], onDelete: Cascade)

  @@unique([fromPersonId, toPersonId, relationshipType])
  @@index([fromPersonId])
  @@index([toPersonId])
  @@index([relationshipType])
  @@index([fromPersonId, relationshipType])
  @@index([toPersonId, relationshipType])
}

model Team {
  id        String       @id @default(cuid())
  projectId String       @unique
  status    TeamStatus   @default(FORMING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members   TeamMember[]

  @@index([status])
}

model TeamMember {
  id            String           @id @default(cuid())
  teamId        String
  personId      String
  roleOpeningId String?
  status        TeamMemberStatus @default(INVITED)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  team          Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  person        Person           @relation(fields: [personId], references: [id], onDelete: Cascade)
  roleOpening   RoleOpening?     @relation(fields: [roleOpeningId], references: [id], onDelete: SetNull)

  @@unique([teamId, personId, roleOpeningId])
  @@index([teamId])
  @@index([personId])
  @@index([roleOpeningId])
  @@index([status])
}

model ProductionConversation {
  id                     String                       @id @default(cuid())
  projectId              String
  provider               ConversationProvider         @default(MOCK)
  externalConversationId String?
  status                 ProductionConversationStatus @default(DRAFT)
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  project                Project                      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  legacyGroupChat        GroupChat?
  tasks                  Task[]

  @@index([projectId])
  @@index([provider])
  @@index([provider, externalConversationId])
  @@index([status])
  @@index([updatedAt])
}

model WebSession {
  id         String           @id @default(cuid())
  createdAt  DateTime         @default(now())
  lastSeenAt DateTime         @updatedAt
  userAgent  String?
  ipHash     String?
  persona    String?
  messages   WebChatMessage[]

  @@index([createdAt])
  @@index([persona])
}

model AdminSession {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @updatedAt
  revokedAt  DateTime?

  @@index([createdAt])
  @@index([revokedAt])
}

model WebChatMessage {
  id             String     @id @default(cuid())
  sessionId      String
  session        WebSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  conversationId String
  role           String
  content        String
  mode           String?
  persona        String?
  route          String?
  nextStep       Json?
  extractedFields Json?
  selectedReplySource String?
  fallbackReason String?
  providerState  String?
  model          String?
  configuredMode String?
  effectiveMode  String?
  operation      String?
  turn           Int
  createdAt      DateTime   @default(now())

  @@index([sessionId, conversationId, createdAt])
  @@index([persona])
  @@index([route])
  @@index([providerState])
  @@index([createdAt])
}

model WebChatRuntimeSetting {
  key                     String   @id
  autonomousEnabled       Boolean  @default(false) @map("autonomous_enabled")
  updatedAt               DateTime @updatedAt @map("updated_at")
  updatedByAdminSessionId String?  @map("updated_by_admin_session_id")
}

model WebChatRuntimeSettingAudit {
  id                  String   @id @default(cuid())
  oldValue            Boolean  @map("old_value")
  newValue            Boolean  @map("new_value")
  actorAdminSessionId String?  @map("actor_admin_session_id")
  createdAt           DateTime @default(now()) @map("created_at")

  @@index([createdAt])
}
