model User {
  id                                String                 @id @default(cuid())
  phone                             String                 @unique
  name                              String?
  hasCompletedFirstTimeHostQuestion Boolean                @default(false)
  smsOptedOutAt                     DateTime?
  createdAt                         DateTime               @default(now())
  updatedAt                         DateTime               @updatedAt
  messages                          Message[]
  projectBriefs                     ProjectBrief[]
  groupChatParticipants             GroupChatParticipant[]
  inboundProcessingJobs             InboundProcessingJob[]
}

model ProjectBrief {
  id                    String                 @id @default(cuid())
  userId                String
  projectId             String?                @unique
  status                ProjectStatus          @default(NEW_INBOUND)
  previousStatus        ProjectStatus?
  escalationReason      String?
  escalationFlags       Json                   @default("[]")
  escalationResolvedAt  DateTime?
  firstTimeHost         Boolean?
  city                  String?
  projectType           String?
  title                 String?
  description           String?
  targetDate            String?
  budgetRange           String?
  expectedAudienceSize  String?
  scope                 String?
  vibe                  String?
  helpNeeded            String?
  requiredRoles         Json                   @default("[]")
  adminNotes            String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  project               Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)
  messages              Message[]
  outreaches            Outreach[]
  groupChats            GroupChat[]
  tasks                 Task[]
  pilotFeedback         PilotFeedback[]
  pilotParticipants     PilotParticipant[]
  shortlistPackets      ShortlistPacket[]
  outboundDrafts        OutboundDraft[]
  llmReviewItems        LlmReviewItem[]
  inboundProcessingJobs InboundProcessingJob[]
  talentSearchRuns      TalentSearchRun[]
  talentResearchReviews TalentResearchReview[]
  publicWebResearchRuns PublicWebResearchRun[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
}

model Message {
  id                    String                 @id @default(cuid())
  direction             MessageDirection
  channel               MessageChannel
  userId                String?
  projectBriefId        String?
  contactId             String?
  twilioMessageSid      String?                @unique
  body                  String
  metadata              Json?
  createdAt             DateTime               @default(now())
  user                  User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  projectBrief          ProjectBrief?          @relation(fields: [projectBriefId], references: [id], onDelete: SetNull)
  contact               Contact?               @relation(fields: [contactId], references: [id], onDelete: SetNull)
  llmReviewItems        LlmReviewItem[]
  inboundProcessingJobs InboundProcessingJob[]

  @@index([userId])
  @@index([projectBriefId])
  @@index([contactId])
  @@index([createdAt])
}

model InboundProcessingJob {
  id                       String                     @id @default(cuid())
  inboundMessageId         String?
  inboundTwilioMessageSid  String?                    @unique
  projectBriefId           String?
  userId                   String?
  contactId                String?
  normalizedSenderHash     String?
  status                   InboundProcessingJobStatus @default(PENDING)
  processingMode           String                     @default("sync")
  attempts                 Int                        @default(0)
  maxAttempts              Int                        @default(3)
  lockedAt                 DateTime?
  lockedBy                 String?
  runAfter                 DateTime?
  lastErrorCategory        String?
  lastErrorMessageRedacted String?
  resultSummary            Json?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  completedAt              DateTime?
  inboundMessage           Message?                   @relation(fields: [inboundMessageId], references: [id], onDelete: SetNull)
  projectBrief             ProjectBrief?              @relation(fields: [projectBriefId], references: [id], onDelete: SetNull)
  user                     User?                      @relation(fields: [userId], references: [id], onDelete: SetNull)
  contact                  Contact?                   @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([runAfter])
  @@index([inboundMessageId])
  @@index([createdAt])
  @@index([processingMode])
  @@index([projectBriefId])
  @@index([userId])
  @@index([contactId])
  @@index([status, runAfter, createdAt])
}

model Contact {
  id                           String                        @id @default(cuid())
  personId                     String?                       @unique
  name                         String
  phone                        String                        @unique
  email                        String?
  city                         String?
  roles                        String[]
  tags                         String[]
  portfolioUrl                 String?
  instagramUrl                 String?
  notes                        String?
  smsOptedOutAt                DateTime?
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt
  person                       Person?                       @relation(fields: [personId], references: [id], onDelete: SetNull)
  messages                     Message[]
  outreaches                   Outreach[]
  groupChatParticipants        GroupChatParticipant[]
  outboundDrafts               OutboundDraft[]
  inboundProcessingJobs        InboundProcessingJob[]
  talentCandidates             TalentCandidate[]
  conversationAutonomySettings ConversationAutonomySetting[]

  @@index([city])
  @@index([city, name])
}

model Outreach {
  id                        String                   @id @default(cuid())
  projectBriefId            String
  contactId                 String
  opportunityId             String?
  candidateRecommendationId String?
  status                    OutreachStatus           @default(DRAFTED)
  draftedMessage            String
  sentMessage               String?
  lastResponse              String?
  adminApproved             Boolean                  @default(false)
  consentToGroupChat        Boolean                  @default(false)
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  projectBrief              ProjectBrief             @relation(fields: [projectBriefId], references: [id], onDelete: Cascade)
  contact                   Contact                  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  opportunity               Opportunity?             @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  candidateRecommendation   CandidateRecommendation? @relation(fields: [candidateRecommendationId], references: [id], onDelete: SetNull)

  @@unique([projectBriefId, contactId])
  @@index([status])
  @@index([projectBriefId])
  @@index([contactId])
  @@index([opportunityId])
  @@index([candidateRecommendationId])
  @@index([updatedAt])
}

model GroupChat {
  id                       String                  @id @default(cuid())
  projectBriefId           String
  productionConversationId String?                 @unique
  twilioConversationSid    String?                 @unique
  status                   GroupChatStatus         @default(DRAFT)
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  projectBrief             ProjectBrief            @relation(fields: [projectBriefId], references: [id], onDelete: Cascade)
  productionConversation   ProductionConversation? @relation(fields: [productionConversationId], references: [id], onDelete: SetNull)
  participants             GroupChatParticipant[]
  tasks                    Task[]

  @@index([projectBriefId])
  @@index([status])
  @@index([updatedAt])
}

model GroupChatParticipant {
  id               String    @id @default(cuid())
  groupChatId      String
  userId           String?
  contactId        String?
  role             String
  phone            String
  consentConfirmed Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  groupChat        GroupChat @relation(fields: [groupChatId], references: [id], onDelete: Cascade)
  user             User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  contact          Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([groupChatId])
  @@index([userId])
  @@index([contactId])
}

model Task {
  id                       String                  @id @default(cuid())
  projectBriefId           String?
  projectId                String?
  groupChatId              String?
  productionConversationId String?
  ownerName                String?
  ownerPhone               String?
  title                    String
  description              String?
  dueDate                  DateTime?
  status                   TaskStatus              @default(TODO)
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  projectBrief             ProjectBrief?           @relation(fields: [projectBriefId], references: [id], onDelete: Cascade)
  project                  Project?                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  groupChat                GroupChat?              @relation(fields: [groupChatId], references: [id], onDelete: SetNull)
  productionConversation   ProductionConversation? @relation(fields: [productionConversationId], references: [id], onDelete: SetNull)

  @@index([projectBriefId])
  @@index([projectId])
  @@index([groupChatId])
  @@index([productionConversationId])
  @@index([status])
  @@index([dueDate])
  @@index([status, dueDate, updatedAt])
}

model AuditLog {
  id         String         @id @default(cuid())
  actorType  AuditActorType
  action     String
  entityType String
  entityId   String
  metadata   Json           @default("{}")
  createdAt  DateTime       @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model PilotFeedback {
  id                 String            @id @default(cuid())
  projectBriefId     String?
  personId           String?
  pilotParticipantId String?
  category           String
  rating             Int?
  notes              String
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  projectBrief       ProjectBrief?     @relation(fields: [projectBriefId], references: [id], onDelete: SetNull)
  person             Person?           @relation(fields: [personId], references: [id], onDelete: SetNull)
  pilotParticipant   PilotParticipant? @relation(fields: [pilotParticipantId], references: [id], onDelete: SetNull)

  @@index([projectBriefId])
  @@index([personId])
  @@index([pilotParticipantId])
  @@index([category])
  @@index([createdAt])
}

model PilotParticipant {
  id                           String                        @id @default(cuid())
  personId                     String?
  projectBriefId               String?
  inviteCodeId                 String?
  phoneHash                    String?
  redactedPhone                String?
  name                         String?
  email                        String?
  role                         PilotParticipantRole          @default(INTERNAL_TEST)
  cohort                       String                        @default("internal")
  status                       PilotParticipantStatus        @default(INVITED)
  consentSource                String?
  consentTimestamp             DateTime?
  joinedAt                     DateTime?
  lastActiveAt                 DateTime?
  notes                        String?
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt
  person                       Person?                       @relation(fields: [personId], references: [id], onDelete: SetNull)
  projectBrief                 ProjectBrief?                 @relation(fields: [projectBriefId], references: [id], onDelete: SetNull)
  inviteCode                   BetaInviteCode?               @relation(fields: [inviteCodeId], references: [id], onDelete: SetNull)
  pilotFeedback                PilotFeedback[]
  consentEvents                ConsentEvent[]
  conversationAutonomySettings ConversationAutonomySetting[]

  @@index([personId])
  @@index([projectBriefId])
  @@index([inviteCodeId])
  @@index([phoneHash])
  @@index([email])
  @@index([role])
  @@index([cohort])
  @@index([status])
  @@index([status, cohort])
  @@index([updatedAt])
}

model BetaInviteCode {
  id                        String                    @id @default(cuid())
  codeHash                  String                    @unique
  label                     String?
  cohort                    String
  maxUses                   Int                       @default(1)
  uses                      Int                       @default(0)
  expiresAt                 DateTime?
  createdBy                 String?
  status                    BetaInviteCodeStatus      @default(ACTIVE)
  metadata                  Json                      @default("{}")
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  pilotParticipants         PilotParticipant[]
  publicBetaWaitlistEntries PublicBetaWaitlistEntry[]

  @@index([cohort])
  @@index([status])
  @@index([expiresAt])
  @@index([createdAt])
}

model PublicBetaWaitlistEntry {
  id                 String                   @id @default(cuid())
  email              String?
  emailHash          String?
  phoneHash          String?
  redactedPhone      String?
  name               String?
  desiredUseCase     PublicBetaUseCase        @default(UNKNOWN)
  city               String?
  fandoms            Json                     @default("[]")
  source             String?
  status             PublicBetaWaitlistStatus @default(PENDING)
  inviteCodeId       String?
  consentCaptured    Boolean                  @default(false)
  consentTextVersion String?
  consentCapturedAt  DateTime?
  notes              String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  inviteCode         BetaInviteCode?          @relation(fields: [inviteCodeId], references: [id], onDelete: SetNull)
  consentEvents      ConsentEvent[]

  @@index([emailHash])
  @@index([phoneHash])
  @@index([desiredUseCase])
  @@index([status])
  @@index([inviteCodeId])
  @@index([createdAt])
  @@index([updatedAt])
}

model ConsentEvent {
  id                 String                   @id @default(cuid())
  participantId      String?
  waitlistEntryId    String?
  phoneHash          String?
  emailHash          String?
  consentType        ConsentEventType
  consentTextVersion String
  consentText        String
  source             ConsentEventSource
  capturedAt         DateTime
  revokedAt          DateTime?
  metadata           Json                     @default("{}")
  createdAt          DateTime                 @default(now())
  participant        PilotParticipant?        @relation(fields: [participantId], references: [id], onDelete: SetNull)
  waitlistEntry      PublicBetaWaitlistEntry? @relation(fields: [waitlistEntryId], references: [id], onDelete: SetNull)

  @@index([participantId])
  @@index([waitlistEntryId])
  @@index([phoneHash])
  @@index([emailHash])
  @@index([consentType])
  @@index([source])
  @@index([capturedAt])
  @@index([createdAt])
}

model BetaCohortSimulationRun {
  id                 String                             @id @default(cuid())
  cohortType         BetaCohortSimulationType
  status             BetaCohortSimulationStatus
  simulatedUserCount Int
  allowedCount       Int                                @default(0)
  waitlistedCount    Int                                @default(0)
  blockedCount       Int                                @default(0)
  escalatedCount     Int                                @default(0)
  transcriptPassRate Float                              @default(0)
  averageScore       Float                              @default(0)
  riskLevel          String
  blockers           Json                               @default("[]")
  warnings           Json                               @default("[]")
  resultSummary      Json                               @default("{}")
  createdAt          DateTime                           @default(now())
  updatedAt          DateTime                           @updatedAt
  memberResults      BetaCohortSimulationMemberResult[]

  @@index([cohortType])
  @@index([status])
  @@index([riskLevel])
  @@index([createdAt])
