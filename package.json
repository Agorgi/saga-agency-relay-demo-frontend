{
  "name": "saga-visual-talent-demo",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "scripts": {
    "dev": "next dev",
    "demo": "next dev -H 0.0.0.0 -p 3000",
    "build": "next build",
    "start": "next start",
    "start:demo": "next start -H 0.0.0.0 -p 3000",
    "demo:prod": "npm run build && npm run start:demo",
    "lint": "eslint .",
    "lint:copy": "tsx scripts/lint-copy.ts",
    "typecheck": "tsc --noEmit",
    "test:sagasan-agent": "tsx --test src/lib/sagasanAgent.test.ts src/lib/sagasanSystemPrompt.test.ts src/lib/webChatNextStep.test.ts src/app/api/web-chat/route.test.ts src/components/AppChrome.test.tsx src/components/web-chat/ChatThread.test.tsx src/components/web-chat/useWebChat.test.ts",
    "test:sagasan-dogfood-docs": "tsx scripts/test-sagasan-dogfood-docs.ts",
    "test:sagasan-model-preflight": "tsx scripts/test-sagasan-model-preflight.ts",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^11.15.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "openai": "^6.36.0",
    "prisma": "^6.19.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "twilio": "^6.0.0",
    "vercel": "^51.8.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.4.0",
    "tailwindcss": "^4",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
