{
  "name": "saga-visual-talent-demo",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "scripts": {
    "dev": "next dev",
    "demo": "next dev -H 0.0.0.0 -p 3000",
    "build": "next build",
    "start": "next start",
    "start:demo": "next start -H 0.0.0.0 -p 3000",
    "demo:prod": "npm run build && npm run start:demo",
    "lint": "eslint .",
    "lint:copy": "tsx scripts/lint-copy.ts",
    "typecheck": "tsc --noEmit",
    "test:sagasan-agent": "tsx --test --test-concurrency=1 src/lib/sagasanOrganizerIntake.test.ts src/lib/sagasanAgent.test.ts src/lib/sagasanSystemPrompt.test.ts src/lib/webChatNextStep.test.ts src/lib/hostBriefHandoff.test.ts src/lib/buildMyCrewContracts.test.ts src/lib/explorerPresentation.test.ts src/lib/publicEventPresentation.test.ts src/lib/journey/journey.test.ts src/lib/projectBriefUpsert.test.ts src/lib/projectBriefView.test.ts src/lib/projectCrewView.test.ts src/lib/candidateReview.test.ts src/lib/observability.test.ts src/lib/projectOutreachView.test.ts src/lib/outreachApproval.test.ts src/lib/projectAuth.test.ts src/components/projects/outreachPrimaryUi.test.ts src/sms-engine/observability/observabilitySummary.test.ts src/app/api/web-chat/route.test.ts src/app/api/admin/test-error/route.test.ts src/components/AppChrome.test.tsx src/components/web-chat/ChatThread.test.tsx src/components/web-chat/useWebChat.test.ts",
    "test:journey": "tsx --test src/lib/journey/journey.test.ts",
    "test:brief-upsert": "tsx --test src/lib/projectBriefUpsert.test.ts",
    "test:brief-view": "tsx --test src/lib/projectBriefView.test.ts",
    "test:crew-view": "tsx --test src/lib/projectCrewView.test.ts",
    "test:candidate-review": "tsx --test src/lib/candidateReview.test.ts",
    "test:sagasan-dogfood-docs": "tsx scripts/test-sagasan-dogfood-docs.ts",
    "test:sagasan-model-preflight": "tsx scripts/test-sagasan-model-preflight.ts",
    "test:user-journey-organizer-intake-quality": "tsx --test src/lib/sagasanOrganizerIntake.test.ts src/lib/sagasanAgent.test.ts",
    "test:conversation-intent-router": "tsx -r tsconfig-paths/register sms-engine/scripts/test-conversation-intent-router.ts",
    "test:conversation-organizer-policy": "tsx -r tsconfig-paths/register sms-engine/scripts/test-conversation-organizer-policy.ts",
    "test:conversation-organizer-multiturn": "tsx -r tsconfig-paths/register sms-engine/scripts/test-conversation-organizer-multiturn.ts",
    "test:conversation-gig-seeker-policy": "tsx -r tsconfig-paths/register sms-engine/scripts/test-conversation-gig-seeker-policy.ts",
    "test:conversation-gig-seeker-multiturn": "tsx -r tsconfig-paths/register sms-engine/scripts/test-conversation-gig-seeker-multiturn.ts",
    "test:conversation-interest-check-policy": "tsx -r tsconfig-paths/register sms-engine/scripts/test-conversation-interest-check-policy.ts",
    "test:conversation-interest-check-multiturn": "tsx -r tsconfig-paths/register sms-engine/scripts/test-conversation-interest-check-multiturn.ts",
    "test:conversation-contact-reply-policy": "tsx -r tsconfig-paths/register sms-engine/scripts/test-conversation-contact-reply-policy.ts",
    "test:conversation-capability-responses": "tsx -r tsconfig-paths/register sms-engine/scripts/test-conversation-capability-responses.ts",
    "test:conversation-golden-transcripts": "tsx -r tsconfig-paths/register sms-engine/scripts/test-conversation-golden-transcripts.ts",
    "test:conversation-engine-v0.1": "npm run test:conversation-intent-router && npm run test:conversation-organizer-policy && npm run test:conversation-organizer-multiturn && npm run test:conversation-gig-seeker-policy && npm run test:conversation-gig-seeker-multiturn && npm run test:conversation-interest-check-policy && npm run test:conversation-interest-check-multiturn && npm run test:conversation-contact-reply-policy && npm run test:conversation-capability-responses && npm run test:conversation-golden-transcripts",
    "test:controlled-live-reply-execution": "tsx -r tsconfig-paths/register sms-engine/scripts/test-controlled-live-reply-execution.ts",
    "test:per-phone-autonomy-controls": "tsx -r tsconfig-paths/register sms-engine/scripts/test-per-phone-autonomy-controls.ts",
    "test:admin-info-architecture": "tsx -r tsconfig-paths/register scripts/test-admin-info-architecture.ts",
    "test:security-hardening": "tsx -r tsconfig-paths/register sms-engine/scripts/test-security-hardening.ts",
    "test:twilio-readiness": "tsx -r tsconfig-paths/register sms-engine/scripts/test-twilio-readiness.ts",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@sentry/nextjs": "^10.53.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^11.15.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "openai": "^6.36.0",
    "prisma": "^6.19.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "twilio": "^6.0.0",
    "vercel": "^51.8.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.4.0",
    "tailwindcss": "^4",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
