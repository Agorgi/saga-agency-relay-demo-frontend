DATABASE_URL=
ADMIN_PASSWORD=
APP_BASE_URL=
INTERNAL_API_KEY=

# Optional for Railway staging/demo mode. Leave blank and set MESSAGING_PROVIDER=MOCK.
# Required only when testing live Twilio SMS/Conversations.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=
TWILIO_CONVERSATIONS_SERVICE_SID=

# Optional. Default is secure validation. Use false only for local manual webhook testing.
TWILIO_VALIDATE_WEBHOOKS=

# Optional. Set to MOCK for Railway staging demos without live SMS.
MESSAGING_PROVIDER=MOCK
CONVERSATION_ENGINE_MODE=shadow
CONVERSATION_ENGINE_ACTIVE=false

# Twilio staging safety controls. Keep real sends disabled unless a controlled
# allowlisted pilot has been explicitly approved.
SMS_SENDS_DISABLED=true
SMS_REQUIRE_ALLOWLIST=true
SMS_ALLOWED_NUMBERS=
TWILIO_STAGING_MODE=

# Standalone pilot/public-launch readiness controls. Defaults stay fail-closed.
PILOT_STAGE=internal_test
PILOT_REPLY_MODE=draft_only
SMS_ACCESS_MODE=allowlist_only
PUBLIC_BETA_ENABLED=false
PUBLIC_BETA_LANDING_ENABLED=false
PUBLIC_BETA_WAITLIST_ENABLED=false
PUBLIC_BETA_PUBLIC_NUMBER_VISIBLE=false
PUBLIC_BETA_REQUIRE_INVITE_CODE=true
PUBLIC_BETA_REQUIRE_CONSENT=true
PUBLIC_BETA_SUPPORT_EMAIL=
PUBLIC_BETA_PRIVACY_URL=
PUBLIC_BETA_TERMS_URL=
PUBLIC_LAUNCH_ENABLED=false
SMS_COMPLIANCE_APPROVED=false
PILOT_SUPPORT_CONTACT=
PILOT_PRIVACY_URL=
PILOT_TERMS_URL=
SMS_DAILY_SEND_CAP=
SMS_PER_NUMBER_DAILY_SEND_CAP=
SMS_AUTONOMOUS_REPLY_DAILY_CAP=
SMS_DAILY_INBOUND_CAP=
PILOT_MAX_ACTIVE_PARTICIPANTS=
PRIVATE_BETA_MAX_ACTIVE_PARTICIPANTS=
PUBLIC_BETA_MAX_ACTIVE_PARTICIPANTS=
PUBLIC_BETA_NEW_USER_DAILY_CAP=
MESSAGE_PROCESSING_MODE=sync

# Talent discovery / public web research. Defaults are internal-only and fail-closed.
PUBLIC_WEB_RESEARCH_ENABLED=false
PUBLIC_WEB_RESEARCH_MODE=disabled
PUBLIC_WEB_RESEARCH_PROVIDER=none
PUBLIC_WEB_RESEARCH_MAX_RESULTS=10
PUBLIC_WEB_RESEARCH_REQUIRE_CITATIONS=true

# Optional LLM provider swap knobs. Leave blank to use deterministic fallback mode or OpenAI defaults.
LLM_PROVIDER=fallback
LLM_MODE=fallback
LLM_TIMEOUT_MS=8000
LLM_DAILY_CALL_CAP=
LLM_LOG_PROMPTS=false
LLM_LOG_OUTPUTS=false
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
