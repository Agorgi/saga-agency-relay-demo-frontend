# Engine
ADMIN_PASSWORD=
APP_BASE_URL=
CONVERSATION_ENGINE_ACTIVE=
CONVERSATION_ENGINE_MODE=
DATABASE_URL=
INTERNAL_API_KEY=
LLM_DAILY_CALL_CAP=
LLM_LOG_OUTPUTS=
LLM_LOG_PROMPTS=
LLM_TIMEOUT_MS=
MESSAGE_PROCESSING_MODE=
MESSAGING_PROVIDER=
NODE_ENV=
# Required when LLM_MODE=active_live; ignored when LLM_MODE=active_mock
OPENAI_API_KEY=
OPENAI_BASE_URL=
# Recommended: gpt-4o-mini for fast intake-conversation latency.
# If unset, src/lib/sagasanAgent.ts falls back to gpt-4o-mini.
# Do NOT set to gpt-5.4-mini — that string was a typo seen in prior deployments
# and is rejected at config-read time.
OPENAI_MODEL=
PORT=
RAILWAY_ENVIRONMENT=

# Pilot
PILOT_MAX_ACTIVE_PARTICIPANTS=
PILOT_PRIVACY_URL=
PILOT_REPLY_MODE=
PILOT_STAGE=
PILOT_SUPPORT_CONTACT=
PILOT_TERMS_URL=
PRIVATE_BETA_MAX_ACTIVE_PARTICIPANTS=

# Public beta / launch
PUBLIC_BETA_ENABLED=
PUBLIC_BETA_LANDING_ENABLED=
PUBLIC_BETA_MAX_ACTIVE_PARTICIPANTS=
PUBLIC_BETA_NEW_USER_DAILY_CAP=
PUBLIC_BETA_PUBLIC_NUMBER_VISIBLE=
PUBLIC_BETA_REQUIRE_CONSENT=
PUBLIC_BETA_REQUIRE_INVITE_CODE=
PUBLIC_BETA_WAITLIST_ENABLED=
PUBLIC_LAUNCH_ENABLED=

# Public web research
PUBLIC_WEB_RESEARCH_ALLOWED_DOMAINS=
PUBLIC_WEB_RESEARCH_BLOCKED_DOMAINS=
PUBLIC_WEB_RESEARCH_ENABLED=
PUBLIC_WEB_RESEARCH_LIVE_DRY_RUN_ALLOWED=
PUBLIC_WEB_RESEARCH_LIVE_DRY_RUN_MAX_QUERIES=
PUBLIC_WEB_RESEARCH_LIVE_DRY_RUN_TAG=
PUBLIC_WEB_RESEARCH_MAX_RESULTS=
PUBLIC_WEB_RESEARCH_MODE=
PUBLIC_WEB_RESEARCH_PROVIDER=
PUBLIC_WEB_RESEARCH_REQUIRE_CITATIONS=
PUBLIC_WEB_RESEARCH_STORE_RAW_RESULTS=

# SMS safety / runtime
SMS_ACCESS_MODE=
SMS_ALLOWED_NUMBERS=
SMS_AUTONOMOUS_REPLY_DAILY_CAP=
SMS_COMPLIANCE_APPROVED=
SMS_DAILY_INBOUND_CAP=
SMS_DAILY_SEND_CAP=
SMS_PER_NUMBER_DAILY_SEND_CAP=
SMS_REQUIRE_ALLOWLIST=
SMS_SENDS_DISABLED=

# active_mock | active_live - defaults to active_mock if unset
LLM_MODE=active_mock

# Master kill switch for autonomous web chat replies.
# When unset or any non-"true" value, the /api/web-chat endpoint accepts and stores
# messages but returns a fixed holding reply WITHOUT calling the LLM/engine.
# Leave disabled in production until human-in-the-loop review is in place.
WEB_CHAT_AUTONOMOUS_RESPONSES_ENABLED=false

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_API_CALLS_FORBIDDEN=
TWILIO_AUTH_TOKEN=
TWILIO_CONVERSATIONS_SERVICE_SID=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=
TWILIO_STAGING_MODE=
TWILIO_VALIDATE_WEBHOOKS=

# Observability (Sentry)
# All Sentry vars are OPTIONAL. When SENTRY_DSN is unset, the SDK is
# a no-op — errors still flow through structured logging
# (src/sms-engine/safeLogging.ts), they just don't ship to Sentry.
# When you flip live, set in Vercel:
#   SENTRY_DSN — server DSN (private; do not commit)
#   NEXT_PUBLIC_SENTRY_DSN — browser DSN; usually the same value
#   SENTRY_ENVIRONMENT — "production" / "preview" / "development"
#   SENTRY_ORG, SENTRY_PROJECT — for source-map upload at build time
#   SENTRY_AUTH_TOKEN — build-time secret, source-map upload only
# beforeSend in sentry.*.config.ts runs the same redactor as the
# structured logger, so emails / phones / OpenAI keys / Twilio SIDs
# are scrubbed before send.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
NEXT_PUBLIC_SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=
SENTRY_AUTH_TOKEN=
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=
